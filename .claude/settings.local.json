    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const p=process.env.CLAUDE_TOOL_INPUT_FILE_PATH||''; if(p.endsWith('.ts')||p.endsWith('.tsx')||p.endsWith('.js')||p.endsWith('.jsx')||p.endsWith('.css')){console.log(JSON.stringify({decision:undefined,reason:'File saved: '+p}))}else{console.log(JSON.stringify({decision:undefined}))}\"",
            "timeout": 5000
          }
        ]
      }
    ]
